{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Mongo": "mongodb://localhost:27017/test-db"
  },
  "RabbitMqConfigurations": {
    "Host": "localhost",
    "Port": 5672,
    "User": "guest",
    "Password": "guest"
  },
  "RabbitMqRetryConfiguration": {
    "MaxRetryAttempts": 3,
    "InitialDelay": "00:00:01",
    "MaxDelay": "00:01:00",
    "BackoffMultiplier": 2.0,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDuration": "00:02:00",
    "EnableDeadLetter": true,
    "EnableCircuitBreaker": true,
    "DeadLetterSuffix": ".dlq"
  },
  "AllowedHosts": "*"
}